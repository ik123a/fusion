# =============================================================================
# Fusion - Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for production, optional in dev with mock fallback)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fusion

# ── Authentication (Clerk) ──────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com
# Leave as placeholder values to run in dev mode without Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_secret_here

# ── AI (OpenAI) ─────────────────────────────────────────────────────────────
# Required for AI features (code suggestions, documentation, analysis)
OPENAI_API_KEY=sk-your-openai-api-key

# ── Queue (Redis) ───────────────────────────────────────────────────────────
# Required for background job processing (BullMQ)
REDIS_URL=redis://localhost:6379

# ── App Settings ─────────────────────────────────────────────────────────────
# Set to "0" to force real DB queries even in development (requires Postgres)
FUSION_USE_MOCK_DB=1

# ── Optional ────────────────────────────────────────────────────────────────
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
